<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_stat_card"
    android:padding="14dp"
    android:layout_marginBottom="8dp">

    <!-- Colored dot -->
    <View
        android:id="@+id/statusDot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="@drawable/bg_dot_green"
        android:layout_marginEnd="12dp"/>

    <!-- Date + Subject -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/itemDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="15 Mar 2026, 10:00 AM"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#0A0F1E"/>

        <TextView
            android:id="@+id/itemSubject"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CSE101"
            android:textSize="11sp"
            android:textColor="#8A96B0"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

    <!-- Present / Absent badge -->
    <TextView
        android:id="@+id/statusBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Present"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#22C55E"
        android:background="@drawable/bg_badge_present"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"/>

</LinearLayout>