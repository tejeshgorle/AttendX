<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0F1E">

    <!-- ══════════════════════════════════════════ -->
    <!-- MAIN CONTENT                               -->
    <!-- ══════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ── TOP BAR ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="14dp"
            android:background="#0A0F1E">

            <!-- Back + Title row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/backBtn"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="←"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="@drawable/bg_back_btn"
                    android:layout_marginEnd="12dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Scan Attendance QR"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>

            </LinearLayout>

            <!-- Subject + Session row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="10dp">

                <!-- Subject card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_dark_card"
                    android:padding="12dp"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SUBJECT"
                        android:textSize="10sp"
                        android:textColor="#6B7FA3"
                        android:letterSpacing="0.06"
                        android:layout_marginBottom="3dp"/>

                    <TextView
                        android:id="@+id/subjectText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Subject: -"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>

                </LinearLayout>

                <!-- Session card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_dark_card"
                    android:padding="12dp"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SESSION"
                        android:textSize="10sp"
                        android:textColor="#6B7FA3"
                        android:letterSpacing="0.06"
                        android:layout_marginBottom="3dp"/>

                    <TextView
                        android:id="@+id/sessionStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Session: Waiting..."
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#22C55E"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Countdown card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_dark_card"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="3dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="TIME REMAINING"
                        android:textSize="10sp"
                        android:textColor="#6B7FA3"
                        android:letterSpacing="0.06"/>

                    <View
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:background="@drawable/bg_dot_amber"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/countdownText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Expires in: --"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#F59E0B"/>

            </LinearLayout>

        </LinearLayout>

        <!-- ── CAMERA VIEWFINDER ── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="0dp">

            <!-- Camera preview -->
            <androidx.camera.view.PreviewView
                android:id="@+id/previewView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#111827"/>

            <!-- Scan frame overlay -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- Dark overlay top -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_scan_overlay"/>

                <!-- Corner TL -->
                <View
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:layout_marginStart="-90dp"
                    android:layout_marginTop="-90dp"
                    android:background="@drawable/ic_corner_tl"/>

                <!-- Corner TR -->
                <View
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:layout_marginStart="90dp"
                    android:layout_marginTop="-90dp"
                    android:background="@drawable/ic_corner_tr"/>

                <!-- Corner BL -->
                <View
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:layout_marginStart="-90dp"
                    android:layout_marginTop="90dp"
                    android:background="@drawable/ic_corner_bl"/>

                <!-- Corner BR -->
                <View
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:layout_marginStart="90dp"
                    android:layout_marginTop="90dp"
                    android:background="@drawable/ic_corner_br"/>

                <!-- Scan hint -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="14dp"
                    android:text="Point camera at the QR code"
                    android:textSize="12sp"
                    android:textColor="#80FFFFFF"
                    android:background="@drawable/bg_hint_pill"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"/>

            </FrameLayout>

        </FrameLayout>

        <!-- ── STEPS ROW ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="4"
            android:background="#F4F6FB"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <!-- Step 1 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_card"
                android:padding="10dp"
                android:layout_marginEnd="4dp">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="1"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="@drawable/bg_step_active"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Scan QR"
                    android:textSize="10sp"
                    android:textColor="#4A5568"
                    android:gravity="center"/>

            </LinearLayout>

            <!-- Step 2 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_card"
                android:padding="10dp"
                android:layout_marginEnd="4dp"
                android:layout_marginStart="4dp">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="2"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="@drawable/bg_step_inactive"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Face Verify"
                    android:textSize="10sp"
                    android:textColor="#4A5568"
                    android:gravity="center"/>

            </LinearLayout>

            <!-- Step 3 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_card"
                android:padding="10dp"
                android:layout_marginEnd="4dp"
                android:layout_marginStart="4dp">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="3"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="@drawable/bg_step_inactive"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GPS Check"
                    android:textSize="10sp"
                    android:textColor="#4A5568"
                    android:gravity="center"/>

            </LinearLayout>

            <!-- Step 4 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_card"
                android:padding="10dp"
                android:layout_marginStart="4dp">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="4"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="@drawable/bg_step_inactive"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Marked!"
                    android:textSize="10sp"
                    android:textColor="#4A5568"
                    android:gravity="center"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- ══════════════════════════════════════════ -->
    <!-- LOADING OVERLAY                            -->
    <!-- ══════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone">

        <androidx.cardview.widget.CardView
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="28dp">

                <ProgressBar
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:indeterminate="true"
                    android:indeterminateTint="#4F6EF7"
                    android:layout_marginBottom="14dp"/>

                <TextView
                    android:id="@+id/loadingText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Processing..."
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#0A0F1E"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Please wait"
                    android:textSize="12sp"
                    android:textColor="#8A96B0"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </FrameLayout>

</FrameLayout>
