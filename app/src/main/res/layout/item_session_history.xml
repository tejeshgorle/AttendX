<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_stat_card"
    android:padding="16dp"
    android:layout_marginBottom="10dp">

    <!-- Session icon -->
    <androidx.cardview.widget.CardView
        android:layout_width="44dp"
        android:layout_height="44dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#EEF1FE"
        android:layout_marginEnd="14dp">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_session"
            app:tint="#4F6EF7"/>

    </androidx.cardview.widget.CardView>

    <!-- Date + subject -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/sessionDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="15 Mar 2026, 10:00 AM"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#0A0F1E"/>

        <TextView
            android:id="@+id/sessionSubject"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Class session"
            android:textSize="12sp"
            android:textColor="#8A96B0"
            android:layout_marginTop="3dp"/>

    </LinearLayout>

    <!-- Student count badge -->
    <LinearLayout
        android:id="@+id/studentCountBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_predictor_card"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp">

        <ImageView
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@drawable/ic_person"
            android:layout_marginEnd="4dp"
            app:tint="#4F6EF7"/>

        <TextView
            android:id="@+id/studentCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#4F6EF7"/>

    </LinearLayout>

</LinearLayout>