<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0F1E">

    <!-- ── DARK HERO SECTION ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Hero Top: Branding + Title -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.38"
            android:padding="28dp"
            android:background="#0A0F1E">

            <!-- Decorative glow blob (top-right) -->
            <View
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_alignParentTop="true"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="-40dp"
                android:layout_marginEnd="-40dp"
                android:background="@drawable/bg_glow_blob_blue"
                android:alpha="0.5"/>

            <!-- AttendX Chip -->
            <LinearLayout
                android:id="@+id/logoChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_chip_blue"
                android:paddingStart="12dp"
                android:paddingEnd="14dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:layout_alignParentTop="true"
                android:layout_marginTop="8dp">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_dot_blue"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ATTENDX"
                    android:textSize="11sp"
                    android:textColor="#4F6EF7"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>
            </LinearLayout>

            <!-- Live badge -->
            <LinearLayout
                android:id="@+id/liveBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_badge_green"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:layout_below="@id/logoChip"
                android:layout_marginTop="16dp">

                <View
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@drawable/bg_dot_green"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Live attendance tracking"
                    android:textSize="11sp"
                    android:textColor="#22C55E"/>
            </LinearLayout>

            <!-- Welcome Title -->
            <TextView
                android:id="@+id/welcomeTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome\nback ."
                android:textSize="34sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:lineSpacingMultiplier="1.15"
                android:layout_below="@id/liveBadge"
                android:layout_marginTop="18dp"/>

            <!-- Subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign in to continue your session"
                android:textSize="13sp"
                android:textColor="#6B7FA3"
                android:layout_below="@id/welcomeTitle"
                android:layout_marginTop="6dp"/>

        </RelativeLayout>

        <!-- ── LIGHT CARD FORM SECTION ── -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.62"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_rounded_top"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="32dp"
                android:paddingBottom="40dp">

                <!-- Section Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign In"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#0A0F1E"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Choose your role to get started"
                    android:textSize="13sp"
                    android:textColor="#8A96B0"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="24dp"/>

                <!-- ── ROLE SELECTOR ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp"
                    android:weightSum="2">

                    <!-- Student Role Card -->
                    <LinearLayout
                        android:id="@+id/roleStudent"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_role_card_active"
                        android:padding="14dp"
                        android:layout_marginEnd="5dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👨‍🎓"
                            android:textSize="22sp"
                            android:layout_marginBottom="6dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Student"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#4F6EF7"/>
                    </LinearLayout>

                    <!-- Teacher Role Card -->
                    <LinearLayout
                        android:id="@+id/roleTeacher"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_role_card_inactive"
                        android:padding="14dp"
                        android:layout_marginStart="5dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👨‍🏫"
                            android:textSize="22sp"
                            android:layout_marginBottom="6dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Teacher"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#2D3748"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- ── EMAIL FIELD ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EMAIL ADDRESS"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#4A5568"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_email"
                        android:layout_marginEnd="12dp"
                        app:tint="#A0AEC0"/>

                    <EditText
                        android:id="@+id/emailET"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="you@university.edu"
                        android:textColorHint="#C0C9DC"
                        android:textSize="14sp"
                        android:textColor="#1A202C"
                        android:inputType="textEmailAddress"
                        android:background="@null"
                        android:paddingStart="0dp"
                        android:imeOptions="actionNext"/>

                </LinearLayout>

                <!-- ── PASSWORD FIELD ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PASSWORD"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#4A5568"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_lock"
                        android:layout_marginEnd="12dp"
                        app:tint="#A0AEC0"/>

                    <EditText
                        android:id="@+id/passwordET"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="••••••••"
                        android:textColorHint="#C0C9DC"
                        android:textSize="14sp"
                        android:textColor="#1A202C"
                        android:inputType="textPassword"
                        android:background="@null"
                        android:paddingStart="0dp"
                        android:imeOptions="actionDone"/>

                    <ImageView
                        android:id="@+id/togglePassword"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_eye"
                        app:tint="#A0AEC0"
                        android:clickable="true"
                        android:focusable="true"/>

                </LinearLayout>

                <!-- Forgot Password -->
                <TextView
                    android:id="@+id/forgotPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Forgot password?"
                    android:textSize="12sp"
                    android:textColor="#4F6EF7"
                    android:layout_gravity="end"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="24dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <!-- ── LOGIN BUTTON ── -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#4F6EF7"
                    android:layout_marginBottom="24dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <Button
                            android:id="@+id/loginBtn"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="Sign In"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:letterSpacing="0.04"
                            android:background="@null"
                            android:stateListAnimator="@null"/>

                        <!-- Arrow chip -->
                        <TextView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:text="→"
                            android:textSize="14sp"
                            android:textColor="#FFFFFF"
                            android:gravity="center"
                            android:background="@drawable/bg_btn_arrow"
                            android:layout_centerVertical="true"
                            android:layout_alignParentEnd="true"
                            android:layout_marginEnd="16dp"/>

                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <!-- ── DIVIDER ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E2E8F4"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  or continue with  "
                        android:textSize="12sp"
                        android:textColor="#A0AEC0"/>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E2E8F4"/>

                </LinearLayout>

                <!-- ── SSO BUTTONS ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="28dp">

                    <!-- Google -->
                    <LinearLayout
                        android:id="@+id/googleSignIn"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="@drawable/bg_sso_btn"
                        android:layout_marginEnd="5dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_google"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Google"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#2D3748"/>

                    </LinearLayout>

                    <!-- College ID (replaces Facebook for education app) -->
                    <LinearLayout
                        android:id="@+id/collegeSignIn"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="@drawable/bg_sso_btn"
                        android:layout_marginStart="5dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_college_id"
                            android:layout_marginEnd="8dp"
                            app:tint="#4F6EF7"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="College ID"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#2D3748"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- ── REGISTER LINK ── -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="New to AttendX? "
                        android:textSize="13sp"
                        android:textColor="#8A96B0"/>

                    <TextView
                        android:id="@+id/registerText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Create account"
                        android:textSize="13sp"
                        android:textColor="#4F6EF7"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true"/>

                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
