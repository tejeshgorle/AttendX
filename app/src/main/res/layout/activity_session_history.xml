<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F6FB">

    <!-- ══════════════════════════════════════════ -->
    <!-- DARK HEADER                                -->
    <!-- ══════════════════════════════════════════ -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0A0F1E"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="20dp"
        android:paddingBottom="32dp">

        <!-- Glow blob -->
        <View
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="-50dp"
            android:layout_marginEnd="-50dp"
            android:background="@drawable/bg_glow_blob_blue"
            android:alpha="0.35"/>

        <!-- Back button -->
        <TextView
            android:id="@+id/backBtn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="←"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="@drawable/bg_back_btn"
            android:layout_alignParentTop="true"
            android:layout_marginTop="8dp"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Title -->
        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Session History"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_below="@id/backBtn"
            android:layout_marginTop="14dp"/>

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All attendance sessions conducted"
            android:textSize="13sp"
            android:textColor="#6B7FA3"
            android:layout_below="@id/titleText"
            android:layout_marginTop="4dp"/>

    </RelativeLayout>

    <!-- ══════════════════════════════════════════ -->
    <!-- CONTENT                                    -->
    <!-- ══════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recent Sessions"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#0A0F1E"/>

    </LinearLayout>

    <!-- Session List -->
    <ListView
        android:id="@+id/listView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@null"
        android:dividerHeight="0dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:clipToPadding="false"/>

</LinearLayout>