<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FB"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ══════════════════════════════════════════ -->
        <!-- DARK HEADER                                -->
        <!-- ══════════════════════════════════════════ -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#0A0F1E"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="48dp">

            <!-- Glow blob -->
            <View
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_alignParentTop="true"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="-50dp"
                android:layout_marginEnd="-50dp"
                android:background="@drawable/bg_glow_blob_blue"
                android:alpha="0.35"/>

            <!-- Back button -->
            <TextView
                android:id="@+id/backBtn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="←"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:background="@drawable/bg_back_btn"
                android:layout_alignParentTop="true"
                android:layout_marginTop="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <!-- Title -->
            <TextView
                android:id="@+id/pageTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="My Profile"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_below="@id/backBtn"
                android:layout_marginTop="14dp"/>

            <!-- Subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage your account details"
                android:textSize="13sp"
                android:textColor="#6B7FA3"
                android:layout_below="@id/pageTitle"
                android:layout_marginTop="4dp"/>

        </RelativeLayout>

        <!-- ══════════════════════════════════════════ -->
        <!-- FLOATING PROFILE CARD                      -->
        <!-- ══════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginTop="-32dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="20dp">

                    <!-- Avatar -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        app:cardCornerRadius="36dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#4F6EF7"
                        android:layout_marginEnd="16dp">

                        <de.hdodenhof.circleimageview.CircleImageView
                            android:id="@+id/profileImage"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_launcher_foreground"
                            android:scaleType="centerCrop"/>

                    </androidx.cardview.widget.CardView>

                    <!-- Name + role + change photo -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/profileNameDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Student"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#0A0F1E"
                            android:layout_marginBottom="3dp"/>

                        <TextView
                            android:id="@+id/profileRoleDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Student"
                            android:textSize="12sp"
                            android:textColor="#8A96B0"
                            android:layout_marginBottom="10dp"/>

                        <!-- Change photo button — TextView avoids Material theme override -->
                        <TextView
                            android:id="@+id/changePhotoBtn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Change Photo"
                            android:textSize="11sp"
                            android:textColor="#4F6EF7"
                            android:textStyle="bold"
                            android:background="@drawable/bg_upload_chip"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="5dp"
                            android:paddingBottom="5dp"
                            android:clickable="true"
                            android:focusable="true"/>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- ══════════════════════════════════════════ -->
        <!-- CONTENT                                    -->
        <!-- ══════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginTop="16dp">

            <!-- ── Attendance Summary Card ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_stat_card"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Attendance Summary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#0A0F1E"
                    android:layout_marginBottom="14dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="4">

                    <!-- Overall -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_summary_chip"
                        android:padding="10dp"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:id="@+id/attendanceSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--%"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#4F6EF7"
                            android:maxLines="1"
                            android:autoSizeTextType="uniform"
                            android:autoSizeMinTextSize="10sp"
                            android:autoSizeMaxTextSize="16sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Overall"
                            android:textSize="10sp"
                            android:textColor="#8A96B0"
                            android:layout_marginTop="3dp"/>

                    </LinearLayout>

                    <!-- Present -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_summary_chip"
                        android:padding="10dp"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:id="@+id/summaryPresent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#22C55E"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Present"
                            android:textSize="10sp"
                            android:textColor="#8A96B0"
                            android:layout_marginTop="3dp"/>

                    </LinearLayout>

                    <!-- Absent -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_summary_chip"
                        android:padding="10dp"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:id="@+id/summaryAbsent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#EF4444"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Absent"
                            android:textSize="10sp"
                            android:textColor="#8A96B0"
                            android:layout_marginTop="3dp"/>

                    </LinearLayout>

                    <!-- Total -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_summary_chip"
                        android:padding="10dp">

                        <TextView
                            android:id="@+id/summaryTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#0A0F1E"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total"
                            android:textSize="10sp"
                            android:textColor="#8A96B0"
                            android:layout_marginTop="3dp"/>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- ── Edit Profile Section ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Edit Profile"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#0A0F1E"
                android:layout_marginBottom="14dp"/>

            <!-- Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FULL NAME"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#4A5568"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_input_field"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="14dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_person"
                    android:layout_marginEnd="12dp"
                    app:tint="#A0AEC0"/>

                <EditText
                    android:id="@+id/nameInput"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="Your full name"
                    android:textColorHint="#C0C9DC"
                    android:textSize="14sp"
                    android:textColor="#1A202C"
                    android:background="@null"
                    android:inputType="textPersonName"
                    android:imeOptions="actionNext"/>

            </LinearLayout>

            <!-- Roll Number -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ROLL NUMBER"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#4A5568"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_input_field"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="14dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_college_id"
                    android:layout_marginEnd="12dp"
                    app:tint="#A0AEC0"/>

                <EditText
                    android:id="@+id/rollInput"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="e.g. 21CSE045"
                    android:textColorHint="#C0C9DC"
                    android:textSize="14sp"
                    android:textColor="#1A202C"
                    android:background="@null"
                    android:inputType="text"
                    android:imeOptions="actionNext"/>

            </LinearLayout>

            <!-- Department -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DEPARTMENT"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#4A5568"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_input_field"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_department"
                    android:layout_marginEnd="12dp"
                    app:tint="#A0AEC0"/>

                <EditText
                    android:id="@+id/departmentInput"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="e.g. Computer Science"
                    android:textColorHint="#C0C9DC"
                    android:textSize="14sp"
                    android:textColor="#1A202C"
                    android:background="@null"
                    android:inputType="text"
                    android:imeOptions="actionDone"/>

            </LinearLayout>

            <!-- ── Update Button ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="52dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#4F6EF7"
                android:layout_marginBottom="12dp">

                <Button
                    android:id="@+id/updateBtn"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="Update Profile"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@null"
                    android:stateListAnimator="@null"/>

            </androidx.cardview.widget.CardView>

            <!-- ── Logout Button ── -->
            <Button
                android:id="@+id/logoutBtn"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Logout"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#EF4444"
                android:background="@drawable/bg_logout_btn"
                android:stateListAnimator="@null"
                android:layout_marginBottom="8dp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
