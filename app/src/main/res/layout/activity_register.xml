<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0F1E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ── DARK HERO SECTION ── -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.32"
            android:padding="28dp"
            android:background="#0A0F1E">

            <!-- Glow blob -->
            <View
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_alignParentTop="true"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="-30dp"
                android:layout_marginEnd="-30dp"
                android:background="@drawable/bg_glow_blob_blue"
                android:alpha="0.4"/>

            <!-- Back button -->
            <TextView
                android:id="@+id/backBtn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="←"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:background="@drawable/bg_back_btn"
                android:layout_alignParentTop="true"
                android:layout_marginTop="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <!-- Title -->
            <TextView
                android:id="@+id/registerTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create your\naccount ."
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:lineSpacingMultiplier="1.15"
                android:layout_below="@id/backBtn"
                android:layout_marginTop="14dp"/>

            <!-- Subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Join AttendX — takes less than a minute"
                android:textSize="13sp"
                android:textColor="#6B7FA3"
                android:layout_below="@id/registerTitle"
                android:layout_marginTop="6dp"/>

        </RelativeLayout>

        <!-- ── LIGHT CARD FORM SECTION ── -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.68"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_rounded_top"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="28dp"
                android:paddingBottom="40dp">

                <!-- ── PROGRESS BAR ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3"
                    android:layout_marginBottom="24dp">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="4dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_progress_done"
                        android:layout_gravity="center_vertical"/>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="4dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_progress_active"
                        android:layout_gravity="center_vertical"/>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="4dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_progress_inactive"
                        android:layout_gravity="center_vertical"/>

                </LinearLayout>

                <!-- ── PROFILE PHOTO UPLOAD CARD ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_input_field"
                    android:padding="14dp"
                    android:layout_marginBottom="20dp"
                    android:clickable="true"
                    android:focusable="true">

                    <!-- Avatar circle -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#4F6EF7"
                        android:layout_marginEnd="14dp">

                        <ImageView
                            android:id="@+id/profileImage"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_launcher_foreground"
                            android:scaleType="centerCrop"/>

                    </androidx.cardview.widget.CardView>

                    <!-- Text -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Profile Photo"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#0A0F1E"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tap to upload your photo"
                            android:textSize="12sp"
                            android:textColor="#8A96B0"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <!-- Upload chip (hidden Button kept for functionality) -->
                    <Button
                        android:id="@+id/uploadImageBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Upload"
                        android:textSize="11sp"
                        android:textColor="#4F6EF7"
                        android:textStyle="bold"
                        android:background="@drawable/bg_upload_chip"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"
                        android:stateListAnimator="@null"
                        android:minHeight="0dp"
                        android:minWidth="0dp"/>

                </LinearLayout>

                <!-- ── NAME FIELD ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FULL NAME"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#4A5568"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginBottom="14dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_person"
                        android:layout_marginEnd="12dp"
                        app:tint="#A0AEC0"/>

                    <EditText
                        android:id="@+id/nameET"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="Your full name"
                        android:textColorHint="#C0C9DC"
                        android:textSize="14sp"
                        android:textColor="#1A202C"
                        android:background="@null"
                        android:inputType="textPersonName"
                        android:imeOptions="actionNext"/>

                </LinearLayout>

                <!-- ── EMAIL FIELD ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EMAIL ADDRESS"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#4A5568"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginBottom="14dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_email"
                        android:layout_marginEnd="12dp"
                        app:tint="#A0AEC0"/>

                    <EditText
                        android:id="@+id/emailET"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="you@university.edu"
                        android:textColorHint="#C0C9DC"
                        android:textSize="14sp"
                        android:textColor="#1A202C"
                        android:background="@null"
                        android:inputType="textEmailAddress"
                        android:imeOptions="actionNext"/>

                </LinearLayout>

                <!-- ── PASSWORD FIELD ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PASSWORD"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#4A5568"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginBottom="20dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_lock"
                        android:layout_marginEnd="12dp"
                        app:tint="#A0AEC0"/>

                    <EditText
                        android:id="@+id/passwordET"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="Min. 8 characters"
                        android:textColorHint="#C0C9DC"
                        android:textSize="14sp"
                        android:textColor="#1A202C"
                        android:background="@null"
                        android:inputType="textPassword"
                        android:imeOptions="actionDone"/>

                    <ImageView
                        android:id="@+id/togglePassword"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_eye"
                        app:tint="#A0AEC0"
                        android:clickable="true"
                        android:focusable="true"/>

                </LinearLayout>

                <!-- ── ROLE SELECTOR ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="I AM A"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#4A5568"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="10dp"/>

                <!-- Hidden RadioGroup to preserve original functionality -->
                <RadioGroup
                    android:id="@+id/roleGroup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone">

                    <RadioButton
                        android:id="@+id/teacherRadio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Teacher"/>

                    <RadioButton
                        android:id="@+id/studentRadio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Student"/>

                </RadioGroup>

                <!-- Visual role cards (control the hidden RadioGroup) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="24dp">

                    <!-- Teacher Card -->
                    <LinearLayout
                        android:id="@+id/roleTeacherCard"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_role_card_active"
                        android:padding="14dp"
                        android:layout_marginEnd="5dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👨‍🏫"
                            android:textSize="22sp"
                            android:layout_marginBottom="6dp"/>

                        <TextView
                            android:id="@+id/teacherCardText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Teacher"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#4F6EF7"/>

                    </LinearLayout>

                    <!-- Student Card -->
                    <LinearLayout
                        android:id="@+id/roleStudentCard"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_role_card_inactive"
                        android:padding="14dp"
                        android:layout_marginStart="5dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👨‍🎓"
                            android:textSize="22sp"
                            android:layout_marginBottom="6dp"/>

                        <TextView
                            android:id="@+id/studentCardText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Student"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#2D3748"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- ── REGISTER BUTTON ── -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#4F6EF7"
                    android:layout_marginBottom="20dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <Button
                            android:id="@+id/registerBtn"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="Create Account"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:letterSpacing="0.04"
                            android:background="@null"
                            android:stateListAnimator="@null"/>

                        <TextView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:text="→"
                            android:textSize="14sp"
                            android:textColor="#FFFFFF"
                            android:gravity="center"
                            android:background="@drawable/bg_btn_arrow"
                            android:layout_centerVertical="true"
                            android:layout_alignParentEnd="true"
                            android:layout_marginEnd="16dp"/>

                    </RelativeLayout>

                </androidx.cardview.widget.CardView>

                <!-- ── LOGIN LINK ── -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Already have an account? "
                        android:textSize="13sp"
                        android:textColor="#8A96B0"/>

                    <TextView
                        android:id="@+id/loginText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sign in"
                        android:textSize="13sp"
                        android:textColor="#4F6EF7"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true"/>

                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
